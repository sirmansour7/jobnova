# ─── API ─────────────────────────────────────────────────────────────────────
# Backend API base URL (no trailing slash). Required in production (Vercel).
# Local:
NEXT_PUBLIC_API_URL=http://localhost:3000
# Production (set in Vercel env): your Render/Railway backend URL
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com

# ─── App ─────────────────────────────────────────────────────────────────────
# Full URL of the frontend (used for redirects and meta tags)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Vercel Analytics — leave empty to disable
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=
