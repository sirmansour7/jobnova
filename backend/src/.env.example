# Copy this file to .env and fill in your values. Never commit .env to git.

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/jobnova?schema=public"

# ── JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ──
JWT_ACCESS_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS
JWT_REFRESH_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS

# ── Server ────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── CORS (comma-separated) ───────────────────
ALLOWED_ORIGINS=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# ── Rate Limiting ─────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# ── Email (Resend) ────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM="JobNova <noreply@jobnova.xyz>"

# ── CV Analysis ───────────────────────────────
CV_ANALYSIS_PROVIDER=rules
# CV_ANALYSIS_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ── AI Chat (Groq) ────────────────────────────
# GROQ_API_KEY=gsk_...

# ── Error Tracking (optional) ────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── Admin Registration (production safety) ───
# ALLOW_ADMIN_REGISTER=false
