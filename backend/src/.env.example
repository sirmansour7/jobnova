# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/jobnova?schema=public"

# JWT Secrets - use strong random strings in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_USE_STRONG_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_USE_STRONG_RANDOM_SECRET

# Server
PORT=3000

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3001

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=10
