########################################
# Jobnova Backend - Example Environment
########################################
# Production: set ALLOWED_ORIGINS to your frontend URL (e.g. https://yourapp.vercel.app).
# Use Neon or other PostgreSQL for DATABASE_URL. Never commit real .env.

# ───────────────────────────────────────
# Server
# ───────────────────────────────────────
# Render/Railway set PORT automatically; default for local.
PORT=3000

# Primary database (local example; production: use Neon connection string)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/jobnova?schema=public"

# CORS: comma-separated allowed origins (production: your Vercel/frontend URL)
# The app reads ALLOWED_ORIGINS. CORS_ORIGIN is a friendly alias only.
CORS_ORIGIN=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001

# ───────────────────────────────────────
# JWT / Auth
# ───────────────────────────────────────
# Generate strong secrets in real environments, e.g.:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_USE_STRONG_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_USE_STRONG_RANDOM_SECRET

# TTLs are not wired yet in code but documented here for consistency.
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Password hashing cost factor
BCRYPT_ROUNDS=12

# ───────────────────────────────────────
# Throttling / Rate limiting
# ───────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ───────────────────────────────────────
# Resend (email - verification & password reset)
# ───────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=JobNova <noreply@jobnova.app>
# Frontend base URL (production: https://yourapp.vercel.app) — used for email links
FRONTEND_URL=http://localhost:3000

